<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup - FullStack Cafe</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(120deg, #fdfbfb 0%, #ebedee 100%);
            display: flex;
            flex-direction: column;
            color: #333;
        }

        header {
            width: 100%;
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
        }

        .signup-wrapper {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        .form-box {
            width: 100%;
            max-width: 420px;
            padding: 40px;
            border-radius: 20px;
            background: #fff;
            border: 1px solid #eee;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            text-align: center;
        }

        .form-box h2 {
            color: #4a3728;
            margin-bottom: 8px;
            font-size: 28px;
        }

        .subtitle {
            color: #8c7e74;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .msg {
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            margin-bottom: 15px;
            display: none;
        }

        .msg.error {
            display: block;
            background: #fff5f5;
            color: #c53030;
        }

        .msg.success {
            display: block;
            background: #f0fff4;
            color: #2f855a;
        }

        .form-box input {
            width: 100%;
            padding: 14px;
            border: 2px solid #edf2f7;
            border-radius: 10px;
            margin-bottom: 12px;
        }

        .form-box button {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: #4a3728;
            color: white;
            font-size: 16px;
            cursor: pointer;
        }

        .form-box button:disabled {
            background: #aaa;
            cursor: not-allowed;
        }

        .footer-links {
            margin-top: 20px;
            font-size: 14px;
        }

        .footer-links a {
            color: #d4a373;
            text-decoration: none;
        }
    </style>
</head>

<body>

<header>
    <%- include('partials/header') %>
</header>

<div class="signup-wrapper">
    <div class="form-box">
        <h2>Create Account</h2>
        <p class="subtitle">Join the FullStack Cafe community</p>

        <div id="message-container" class="msg"></div>

        <form id="signupForm">
            <input type="text" name="name" placeholder="Full Name" required>
            <input type="email" name="email" placeholder="Email Address" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit" id="submitBtn">Create Account</button>
        </form>

        <div class="footer-links">
            Already have an account? <a href="/login">Login</a>
        </div>
    </div>
</div>

<script>
const signupForm = document.getElementById('signupForm');
const msgDiv = document.getElementById('message-container');
const submitBtn = document.getElementById('submitBtn');

signupForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.innerText = "Creating...";
    submitBtn.disabled = true;

    msgDiv.style.display = 'none';
    msgDiv.className = "msg";

    const formData = new FormData(signupForm);
    const data = Object.fromEntries(formData.entries());

    try {
        const response = await fetch('/signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            msgDiv.innerText = "OTP sent successfully! Redirecting...";
            msgDiv.classList.add('success');

            setTimeout(() => {
                window.location.href = "/verify-otp?email=" + encodeURIComponent(result.email);
            }, 1500);

        } else {
            msgDiv.innerText = result.message || "Signup failed";
            msgDiv.classList.add('error');
        }

    } catch (err) {
        msgDiv.innerText = "Server error. Please try again.";
        msgDiv.classList.add('error');
    }

    submitBtn.innerText = "Create Account";
    submitBtn.disabled = false;
});
</script>

</body>
</html>